# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon

# Server-only (KHÔNG prefix NEXT_PUBLIC)
SUPABASE_SERVICE_KEY=eyJ...service-role

# Azure VM backend
AZURE_BACKEND_URL=http://your-vm-ip:3001
AZURE_API_SECRET_KEY=match-API_SECRET_KEY-in-backend

# Translation API keys (server-side, không lộ về client)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
