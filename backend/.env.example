# Tomato Novel Downloader
TOMATO_API_URL=http://tomato-downloader:18423
TOMATO_PASSWORD=change_me

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key

# Backend
PORT=3001
API_SECRET_KEY=change_me_long_random_string

# Thư mục mà Tomato Downloader ghi file EPUB ra (mount cùng volume với container Tomato)
TOMATO_DOWNLOAD_DIR=/data

# Cron expression. Mặc định mỗi 8 tiếng. Để trống "" thì tắt cron.
CRON_SCHEDULE=0 */8 * * *

# DS2API internal DeepSeek bridge (Hugging Face single-container deploy)
DS2API_BASE_URL=http://127.0.0.1:5001
DS2API_ADMIN_KEY=change_me_admin_key
# Set one of these in production. Do not commit real DeepSeek account config.
DS2API_CONFIG_JSON=
DS2API_CONFIG_PATH=/data/ds2api/config.json
